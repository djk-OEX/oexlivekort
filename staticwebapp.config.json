{
  "routes": [
    {
      "route": "/login",
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout",
      "statusCode": 302
    },

    // >>> OEX: Åbn ALLE API-ruter for anonymous (nødvendigt for /api/wfs-stops, /api/stops, /api/departures)
    {
      "route": "/api/*",
      "allowedRoles": [ "anonymous" ]
    },

    // Alt andet kræver fortsat login (som før)
    {
      "route": "/*",
      "allowedRoles": [ "authenticated" ]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=.referrer"
    },
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  },

  // Sørg for at SPA-routing ikke sluger /api/*
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/assets/*",
      "/*.{png,jpg,jpeg,gif,ico,css,js}"
    ]
  }
}
